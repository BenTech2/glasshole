<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Debug"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="16dp" />

        <!-- Connection status -->
        <TextView
            android:id="@+id/debugStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking..."
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Test notification card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test notification"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sends a notification through the same pipeline real apps use — glass parses it and shows a card."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/debugAppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="App name"
                android:text="GlassHole"
                android:singleLine="true"
                android:inputType="text" />

            <EditText
                android:id="@+id/debugTitleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Title (optional)"
                android:text="Test title"
                android:singleLine="true"
                android:inputType="text" />

            <EditText
                android:id="@+id/debugTextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Body text"
                android:text="This is a test notification from the debug screen"
                android:minLines="2"
                android:inputType="textMultiLine|textCapSentences"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugSendButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send Plain (no actions)"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugSendReplyButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="With reply action"
                android:textAllCaps="false"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugSendOpenOnDeviceButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="With Open on Phone"
                android:textAllCaps="false"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugSendStreamButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="With YouTube link (Watch on Glass)"
                android:textAllCaps="false"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugSendMultiButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="With multi-action (reply + open)"
                android:textAllCaps="false"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugSendImageButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="With image preview"
                android:textAllCaps="false"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Glass Home: clear the "already prompted" flag for the device-
             admin (screen-off) permission so the user sees the opt-in
             dialog on their next open of GlassHole Home. Useful if they
             tapped "Skip" the first time and now want to enable sleep. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Glass Home"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Re-show the device-admin prompt on the glass so the user can enable screen-off."
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/debugResetAdminPromptButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Re-prompt admin on glass"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
