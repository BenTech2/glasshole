<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Broadcast (RTMP)"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stream the glass camera to any RTMP endpoint (Twitch, YouTube Live, OBS, a local nginx-rtmp, etc). Format: rtmp://server/app/stream_key"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="20dp" />

        <!-- RTMP URL -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="RTMP URL + stream key"
            app:endIconMode="password_toggle"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/urlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Video resolution -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resolution"
            android:textSize="14sp"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/resolutionSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- FPS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Frame rate"
            android:textSize="14sp"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/fpsSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Bitrate -->
        <TextView
            android:id="@+id/bitrateLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bitrate"
            android:textSize="14sp"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/bitrateSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Audio toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Include microphone audio"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/audioSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Display mode -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Glass display while streaming"
            android:textSize="14sp"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/displayGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioViewfinder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show viewfinder (screen on)" />

            <RadioButton
                android:id="@+id/radioPreviewOff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preview hidden (screen stays lit)" />

            <RadioButton
                android:id="@+id/radioScreenOff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Screen off after 3 seconds" />

            <RadioButton
                android:id="@+id/radioChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show chat instead of viewfinder" />
        </RadioGroup>

        <!-- Chat overlay settings — only relevant when the display mode is
             "Show chat instead of viewfinder". Independent of the separate
             Chat plugin; both can be configured differently. -->
        <LinearLayout
            android:id="@+id/chatOverlayCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chat overlay"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shown on the glass when the display mode above is set to chat. The camera RTMP stream is unaffected."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/chatPlatformGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/chatRadioTwitch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Twitch" />

                <RadioButton
                    android:id="@+id/chatRadioYouTube"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="YouTube" />
            </RadioGroup>

            <!-- Twitch sub-card -->
            <LinearLayout
                android:id="@+id/chatTwitchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Twitch channel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/chatTwitchChannelInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- YouTube sub-card -->
            <LinearLayout
                android:id="@+id/chatYouTubeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="YouTube Data API v3 key"
                    app:endIconMode="password_toggle"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/chatYouTubeApiKeyInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Live video URL or ID">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/chatYouTubeVideoInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/chatFontSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font size: 14sp"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/chatFontSizeSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/chatMaxMessagesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat cache: 200 messages"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/chatMaxMessagesSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
