<?xml version="1.0" encoding="utf-8"?>
<!-- SPDX-License-Identifier: MIT
     GlassHole phone-side companion for the GlassNav glass plugin.
     Provides destination search (Nominatim) + send-to-glass + an
     opt-in location streaming toggle. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GlassNav"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/glassNavStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search a destination + tap a result to send it to glass."
        android:textSize="13sp"
        android:textColor="#90A4AE"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <Switch
            android:id="@+id/glassNavLocStream"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stream phone GPS to glass" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#37474F"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/glassNavQuery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search address / place"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/glassNavSearchBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/glassNavResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
