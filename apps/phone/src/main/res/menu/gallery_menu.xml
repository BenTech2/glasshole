<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <item
        android:id="@+id/galleryMenuUpload"
        android:icon="@drawable/ic_upload"
        android:title="Upload from phone"
        app:showAsAction="ifRoom" />

    <!-- Picker filter toggle. When unchecked (default) the upload
         picker accepts only images + videos so accidental other-file
         picks are filtered out. Check it to widen the picker to all
         file types — useful for pushing APKs / audio / archives
         through the gallery channel as a recovery affordance. -->
    <item
        android:id="@+id/galleryMenuUploadAnyType"
        android:title="Upload: allow any file type"
        android:checkable="true"
        android:checked="false"
        app:showAsAction="never" />

    <item
        android:id="@+id/galleryMenuRefresh"
        android:icon="@drawable/ic_refresh"
        android:title="Refresh"
        app:showAsAction="ifRoom" />
</menu>
