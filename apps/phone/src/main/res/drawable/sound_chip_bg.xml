<?xml version="1.0" encoding="utf-8"?>
<!-- Pill-shaped background for the per-app sound chip — same shape as
     a Material assist chip but doesn't pull in the dependency. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceContainerHighest" />
    <stroke android:width="1dp" android:color="?attr/colorOutlineVariant" />
    <corners android:radius="16dp" />
</shape>
