<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 40% alpha so a Home wallpaper subtly shows through behind the
         topbar. With no wallpaper the cards sit on the activity_home
         #000000 root, so the alpha reveals the same black and looks
         identical to a solid gradient. -->
    <gradient
        android:startColor="#662A2A2A"
        android:centerColor="#661A1A1A"
        android:endColor="#660A0A0A"
        android:angle="270" />
</shape>
