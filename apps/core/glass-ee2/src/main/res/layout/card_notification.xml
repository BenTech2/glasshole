<?xml version="1.0" encoding="utf-8"?>
<!-- Glass-style notification card. Front card mirrors the popup/drawer
     visual language (pure black, large light type, no top bar). When
     more than one notification is queued, two thin "behind cards" peek
     above the front to imply a Time Machine–style stack — purely
     decorative; tapping anywhere still opens the scrollable drawer.
     The total count sits centered at the bottom of the screen.

     Implementation: vertical LinearLayout. Top fixed-height "stack
     region" hosts the slivers via an overlapping FrameLayout; the
     remaining weight=1 region holds the front card. Done this way
     because nesting the front card in a FrameLayout with
     layout_marginTop="28dp" was being silently ignored by ViewPager2
     pages — the picture stretched full-bleed instead of clipping. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Stack region: hosts the two back cards. Each is a real card
         shape (rounded top corners, hairline border, black fill matching
         the front card) so the stack feels uniform — only difference is
         the back cards are progressively narrower and dimmer. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:clipChildren="false">

        <!-- Deepest back card — narrower, dimmer. Visible when 3+ notifs
             queued. Tall enough that its bottom is well past the closer
             card's footprint and hidden by the front card, so no cut-off
             edge is visible. -->
        <View
            android:id="@+id/notifStack2"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="top"
            android:layout_marginStart="80dp"
            android:layout_marginEnd="80dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/notif_stack_back"
            android:alpha="0.6"
            android:visibility="gone" />

        <!-- Closer back card — wider, brighter. Visible when 2+ notifs queued. -->
        <View
            android:id="@+id/notifStack1"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="top"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/notif_stack_back"
            android:alpha="0.9"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Front card region — weight=1 takes all remaining vertical space.
         Matches the back-card shape (rounded top corners, hairline
         border) so the stack reads as one deck. The card spills off
         the bottom of the screen for a more natural "open" feel; sides
         are inset slightly so the back cards still look wider behind.
         clipToOutline is set in code so the full-bleed picture respects
         the rounded top. -->
    <FrameLayout
        android:id="@+id/notifFrontCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/notif_front_card">

        <ImageView
            android:id="@+id/notifPicture"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Notification picture" />

        <View
            android:id="@+id/notifPictureGradient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/notif_picture_gradient"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/notifContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="10dp"
            android:paddingBottom="36dp">

            <View
                android:id="@+id/notifTopSpacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

            <TextView
                android:id="@+id/notifTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.02"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/notifBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#DDDDDD"
                android:textSize="24sp"
                android:fontFamily="sans-serif-thin"
                android:lineSpacingMultiplier="1.1"
                android:maxLines="3"
                android:ellipsize="end"
                android:text="" />

            <View
                android:id="@+id/notifMiddleSpacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/notifAppIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="App icon" />

                <TextView
                    android:id="@+id/notifAppText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#888888"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />

                <TextView
                    android:id="@+id/notifTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DDDDDD"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-light"
                    android:maxLines="1"
                    android:text="" />

            </LinearLayout>

        </LinearLayout>

        <!-- Total-count overlay anchored to the bottom of the front card.
             Hidden when only one notification is queued — the absence of
             slivers already implies single. -->
        <TextView
            android:id="@+id/notifStackCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:textColor="#FFC107"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:visibility="gone"
            android:text="" />

        <TextView
            android:id="@+id/notifEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#666666"
            android:textSize="18sp"
            android:fontFamily="sans-serif-light"
            android:text="No notifications" />

    </FrameLayout>

</LinearLayout>
