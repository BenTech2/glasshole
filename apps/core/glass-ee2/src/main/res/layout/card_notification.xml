<?xml version="1.0" encoding="utf-8"?>
<!-- Glass-style notification card, identical language to the popup and
     drawer: pure black, content floats, no topbar/divider. Optional
     picture layers underneath the text as a full-bleed background with
     a dark gradient at the bottom for legibility. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/notifPicture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Notification picture" />

    <View
        android:id="@+id/notifPictureGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/notif_picture_gradient"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/notifContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="26dp"
        android:paddingBottom="18dp">

        <!-- Pushes title/body down to the bottom when a picture is shown. -->
        <View
            android:id="@+id/notifTopSpacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <TextView
            android:id="@+id/notifTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="1.02"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/notifBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#DDDDDD"
            android:textSize="28sp"
            android:fontFamily="sans-serif-thin"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="4"
            android:ellipsize="end"
            android:text="" />

        <!-- Pushes footer to the bottom when there's no picture. -->
        <View
            android:id="@+id/notifMiddleSpacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/notifAppIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="App icon" />

            <TextView
                android:id="@+id/notifAppText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#888888"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/notifTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:textColor="#DDDDDD"
                android:textSize="20sp"
                android:fontFamily="sans-serif-light"
                android:maxLines="1"
                android:text="" />

            <TextView
                android:id="@+id/notifCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFC107"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:text="" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/notifEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#666666"
        android:textSize="18sp"
        android:fontFamily="sans-serif-light"
        android:text="No notifications" />

</FrameLayout>
