<?xml version="1.0" encoding="utf-8"?>
<!-- The label/title is rendered once at the activity level (overlayLabel
     in activity_app_drawer.xml) so it stays stationary while the icons
     scroll past, and is animated on page-settle. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingTop="24dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.glasshole.glassee2.home.ReflectionImageView
        android:id="@+id/appIcon"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/app_icon_tile"
        android:padding="14dp"
        android:scaleType="fitCenter"
        android:contentDescription="App icon" />

    <!-- Reserves space below the icon for the reflection (which draws
         outside the ReflectionImageView's measured bounds). -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="36dp" />

</LinearLayout>
