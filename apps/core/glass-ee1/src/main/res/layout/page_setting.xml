<?xml version="1.0" encoding="utf-8"?>
<!-- A single Settings drawer tile. Same visual language as the app
     drawer's page_app (white rounded tile around an icon + label
     below) so the carousel feels consistent. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">

    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/settings_tile_bg">

        <ImageView
            android:id="@+id/settingIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:padding="40dp"
            android:scaleType="fitCenter"
            android:contentDescription="Setting icon" />

    </FrameLayout>

    <TextView
        android:id="@+id/settingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

</LinearLayout>
