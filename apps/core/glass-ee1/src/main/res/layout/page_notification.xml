<?xml version="1.0" encoding="utf-8"?>
<!-- Mirrors the popup card layout:
     - no picture  → title anchors to the top, footer to the bottom
     - with picture → title/body stack at the bottom over the dark gradient
     Two weight-1 spacers toggle on/off in the adapter to switch layouts.
     "TAP FOR OPTIONS" hint sits just above the footer, matching the
     popup's affordance. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/pagePicture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Notification picture" />

    <View
        android:id="@+id/pagePictureGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/notif_picture_gradient"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="26dp"
        android:paddingBottom="18dp">

        <!-- Pushes title/body down to the bottom when a picture is shown. -->
        <View
            android:id="@+id/pageTopSpacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <TextView
            android:id="@+id/pageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="1.02"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/pageBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#DDDDDD"
            android:textSize="28sp"
            android:fontFamily="sans-serif-thin"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="5"
            android:ellipsize="end"
            android:text="" />

        <!-- Pushes hint/footer to the bottom when there's no picture. -->
        <View
            android:id="@+id/pageMiddleSpacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/pageHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="4dp"
            android:textColor="#4FC3F7"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:text="TAP FOR OPTIONS" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/pageAppIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="App icon" />

            <TextView
                android:id="@+id/pageAppText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#888888"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/pageTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DDDDDD"
                android:textSize="20sp"
                android:fontFamily="sans-serif-light"
                android:maxLines="1"
                android:text="" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
