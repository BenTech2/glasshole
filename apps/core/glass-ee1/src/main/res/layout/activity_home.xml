<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:descendantFocusability="blocksDescendants">

    <!-- User-supplied wallpaper. HomeActivity loads the first image
         in /sdcard/GlassHole/backgrounds/ (case-insensitive .jpg /
         .png) into this view in onResume. Drawn first → underneath
         every other UI element. -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Wallpaper" />

    <!-- Translucent black layer on top of the wallpaper. Alpha is
         driven by BaseSettings.KEY_BACKGROUND_FADE (0..255) from the
         phone-side fade slider so the user can dial in enough dim
         for UI text to stay readable. -->
    <View
        android:id="@+id/backgroundFade"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/cardPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:descendantFocusability="blocksDescendants" />

    <include
        android:id="@+id/mediaOverlay"
        layout="@layout/overlay_media_controls"
        android:visibility="gone" />

    <!-- Idle-dim sleep overlay. Full-screen solid black drawn over every
         other view; paired with screenBrightness=0 so the display really
         does look off, even on panels whose backlight doesn't go dark
         with 0.0 brightness alone. Any touch input raises it. -->
    <View
        android:id="@+id/sleepOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone" />

</FrameLayout>
