<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher-flavor manifest overlay. Merged with src/main/AndroidManifest.xml.
    Adds the HOME + DEFAULT categories to HomeActivity so XE Glass treats
    it as a valid home replacement; overrides the app label so the user
    can tell the two APKs apart in Settings ▸ Apps.

    Everything else (permissions, services, receivers, the other activities)
    comes from the main manifest.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        tools:replace="android:label"
        android:label="GlassHole Launcher">

        <activity android:name=".home.HomeActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".home.HomeDeviceAdminReceiver"
            android:label="GlassHole Home Sleep"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/home_device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
