<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D0000000"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:id="@+id/overlayTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

    <TextView
        android:id="@+id/overlayArtist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_skip_prev"
            android:contentDescription="Previous track" />

        <ImageView
            android:id="@+id/overlayPlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_play"
            android:contentDescription="Play / pause" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="Next track" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="#888888"
        android:textSize="11sp"
        android:text="tap · swipe · swipe down to close" />

</LinearLayout>
