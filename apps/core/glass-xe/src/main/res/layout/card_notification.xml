<?xml version="1.0" encoding="utf-8"?>
<!-- Glass-style notification card. Front card mirrors the popup/drawer
     visual language (pure black, large light type, no top bar). When
     more than one notification is queued, two thin "behind cards" peek
     above the front to imply a Time Machine–style stack — purely
     decorative; tapping anywhere still opens the scrollable drawer.
     The total count sits centered at the bottom of the screen.

     All sizes ~⅔ of EE2 to fit XE's 240dpi 360px-tall screen.

     Implementation: vertical LinearLayout. Top fixed-height "stack
     region" hosts the back-card slivers via an overlapping FrameLayout;
     the remaining weight=1 region holds the front card. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Stack region: hosts the two back cards. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:clipChildren="false">

        <!-- Deepest back card — visible when 3+ notifs queued. -->
        <View
            android:id="@+id/notifStack2"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="top"
            android:layout_marginStart="52dp"
            android:layout_marginEnd="52dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/notif_stack_back"
            android:alpha="0.6"
            android:visibility="gone" />

        <!-- Closer back card — visible when 2+ notifs queued. -->
        <View
            android:id="@+id/notifStack1"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="top"
            android:layout_marginStart="26dp"
            android:layout_marginEnd="26dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/notif_stack_back"
            android:alpha="0.9"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Front card region — weight=1 takes all remaining vertical space. -->
    <FrameLayout
        android:id="@+id/notifFrontCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="9dp"
        android:layout_marginEnd="9dp"
        android:background="@drawable/notif_front_card">

        <ImageView
            android:id="@+id/notifPicture"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Notification picture" />

        <View
            android:id="@+id/notifPictureGradient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/notif_picture_gradient"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/notifContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="20dp">

            <View
                android:id="@+id/notifTopSpacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

            <TextView
                android:id="@+id/notifTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.02"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/notifBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#DDDDDD"
                android:textSize="15sp"
                android:fontFamily="sans-serif-thin"
                android:lineSpacingMultiplier="1.1"
                android:maxLines="3"
                android:ellipsize="end"
                android:text="" />

            <View
                android:id="@+id/notifMiddleSpacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/notifAppIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="App icon" />

                <TextView
                    android:id="@+id/notifAppText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />

                <TextView
                    android:id="@+id/notifTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DDDDDD"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:maxLines="1"
                    android:text="" />

            </LinearLayout>

        </LinearLayout>

        <!-- Total-count overlay anchored to the bottom of the front card. -->
        <TextView
            android:id="@+id/notifStackCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="4dp"
            android:textColor="#FFC107"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:visibility="gone"
            android:text="" />

        <TextView
            android:id="@+id/notifEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#666666"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light"
            android:text="No notifications" />

    </FrameLayout>

</LinearLayout>
