<?xml version="1.0" encoding="utf-8"?>
<!-- The label/title is rendered once at the activity level (overlayLabel
     in activity_app_drawer.xml) so it stays stationary while the icons
     scroll past, and is animated on page-settle. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingTop="24dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 110dp icon tile sized for Glass XE's 360px-tall display: ×1.5
         density gives 165px, plus the cover-flow center emphasis (×1.22)
         leaves the active page at ~200px so the label still fits below
         and neighbors stay visible. -->
    <com.glasshole.glassxe.home.ReflectionImageView
        android:id="@+id/appIcon"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/app_icon_tile"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:contentDescription="App icon" />

    <!-- Reserves space below the icon for the reflection (which draws
         outside the ReflectionImageView's measured bounds). -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="36dp" />

</LinearLayout>
