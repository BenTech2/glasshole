<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/navContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/navTurnIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="fitCenter"
            android:contentDescription="Turn icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- Maps puts distance ("0.5 mi") OR the upcoming maneuver text
                 ("Exit the parking lot toward …") in this slot, depending
                 on trip phase. Cap at 2 lines + ellipsize so a long
                 maneuver string can't push the rest of the card off-screen. -->
            <TextView
                android:id="@+id/navDistanceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/navInstructionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/navEtaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="" />

            <ProgressBar
                android:id="@+id/navProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:max="1000"
                android:progress="0"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
