<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Lets us set CaptureRequest.LED_TRANSMIT = OFF to suppress the
         camera privacy LED. Permission is signature|privileged on stock
         Glass EE2 so the runtime grant request silently denies — but
         the manifest entry, the runtime request flow, and the LED_TRANSMIT
         capture request key plumbing are all in place for any future
         platform-signed / rooted build. -->
    <uses-permission android:name="android.permission.CAMERA_DISABLE_TRANSMIT_LED" />

    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.any" android:required="true" />

    <application
        android:allowBackup="true"
        android:label="Camera"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <meta-data
            android:name="com.google.android.glass.TouchEnabledApplication"
            android:value="true" />

        <service
            android:name=".Camera2PluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.glasshole.plugin.GLASS_PLUGIN" />
            </intent-filter>
            <meta-data android:name="com.glasshole.plugin.ID" android:value="camera2" />
            <meta-data android:name="com.glasshole.plugin.NAME" android:value="Camera" />
            <meta-data android:name="com.glasshole.plugin.DESCRIPTION"
                android:value="Camera2-based stills + video capture" />
            <meta-data android:name="com.glasshole.plugin.SCHEMA"
                android:resource="@raw/plugin_schema" />
        </service>

        <!--
            Primary camera activity. High-priority intent filters so this
            replaces the stock Glass camera for the standard capture entry
            points: camera button, lockscreen shortcut, and third-party
            "take a picture" intents.
        -->
        <activity
            android:name=".CameraActivity"
            android:label="Camera"
            android:exported="true"
            android:screenOrientation="landscape"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
            <!-- Launcher tile (Glass app drawer) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.google.android.glass.category.DIRECTORY" />
            </intent-filter>

            <!-- Replace default camera — hardware camera key + camera-button intent -->
            <intent-filter android:priority="1000">
                <action android:name="android.media.action.STILL_IMAGE_CAMERA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.media.action.STILL_IMAGE_CAMERA_SECURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.media.action.IMAGE_CAPTURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.media.action.IMAGE_CAPTURE_SECURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.media.action.VIDEO_CAPTURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.CAMERA_BUTTON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Hold-to-record control actions, fired by the
                 accessibility service when the user globally
                 press-and-holds the camera key. -->
            <intent-filter android:priority="1000">
                <action android:name="com.glasshole.plugin.camera2.glass.action.RECORD_HOLD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="com.glasshole.plugin.camera2.glass.action.STOP_RECORDING" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="com.glasshole.plugin.camera2.glass.action.RECORD_TIMED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Catches the global camera-button broadcast (hardware key on
             EE2, plus any app/system source that fires ACTION_CAMERA_BUTTON).
             High priority so we win over the stock Glass camera if both
             are installed. The receiver re-launches CameraActivity in
             quick-capture mode. -->
        <receiver
            android:name=".CameraButtonReceiver"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.CAMERA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- Runtime-permission shim for CAMERA_DISABLE_TRANSMIT_LED. Fires
             ActivityCompat.requestPermissions; on stock Glass EE2 the
             system silently denies (signature|privileged), but the same
             entry point can be re-fired on a future privileged build. -->
        <activity
            android:name=".CameraLedPermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
