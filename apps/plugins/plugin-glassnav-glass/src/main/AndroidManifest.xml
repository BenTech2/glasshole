<?xml version="1.0" encoding="utf-8"?>
<!--
SPDX-License-Identifier: GPL-3.0-or-later
Port of GlassNav (https://github.com/CatotheCat11/GlassNav) by CatotheCat11.
See AUTHORS for attribution + LICENSE for terms.

Manifest is GlassNav's verbatim, plus a `GlassPluginService` entry so
the GlassHole launcher's plugin discovery picks this up like any
other plugin (BT bridge into BluetoothMapsService happens through
that service, not RFCOMM as in upstream).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="com.google.android.glass.permission.DEVELOPMENT" />

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:replace="android:label"
        tools:targetApi="31" >

        <meta-data
            android:name="com.google.android.glass.TouchEnabledApplication"
            android:value="true" />

        <activity
            android:name="com.cato.glassnav.MainActivity"
            android:exported="true"
            android:theme="@style/AppTheme"
            android:immersive="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <action android:name="com.google.android.glass.action.VOICE_TRIGGER" />
                <category android:name="com.google.android.glass.category.DIRECTORY"/>
            </intent-filter>
        </activity>
        <activity
            android:name="com.cato.glassnav.SearchActivity"
            android:exported="true" />
        <activity
            android:name="com.cato.glassnav.RouteActivity"
            android:exported="true" />

        <!-- GlassHole BT bridge entry — launcher's plugin discovery
             binds this and forwards phone messages here. The service
             relays them to MainActivity via a registered listener. -->
        <service
            android:name="com.cato.glassnav.GlassNavPluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.glasshole.plugin.GLASS_PLUGIN" />
            </intent-filter>
            <meta-data android:name="com.glasshole.plugin.ID" android:value="glassnav" />
            <meta-data android:name="com.glasshole.plugin.NAME" android:value="GlassNav" />
            <meta-data android:name="com.glasshole.plugin.DESCRIPTION"
                android:value="Turn-by-turn navigation with VTM vector maps. Port of CatotheCat11/GlassNav." />
            <!-- Points the phone-side PluginDirectoryScanner at our
                 settings schema so the gear icon shows up. -->
            <meta-data android:name="com.glasshole.plugin.SCHEMA"
                android:resource="@raw/plugin_schema" />
        </service>
    </application>
</manifest>
