<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- INTERNET only used in the unlikely case we ever do direct calls
         from glass; today the phone proxies every AI request over BT. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:allowBackup="true"
        android:label="AI Assistant"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <meta-data
            android:name="com.google.android.glass.TouchEnabledApplication"
            android:value="true" />

        <service
            android:name=".AiAssistantPluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.glasshole.plugin.GLASS_PLUGIN" />
            </intent-filter>
            <meta-data android:name="com.glasshole.plugin.ID" android:value="ai" />
            <meta-data android:name="com.glasshole.plugin.NAME" android:value="AI Assistant" />
            <meta-data android:name="com.glasshole.plugin.DESCRIPTION"
                android:value="Voice in, AI response on glass (OpenAI / Anthropic / Gemini)" />
            <meta-data android:name="com.glasshole.plugin.SCHEMA"
                android:resource="@raw/plugin_schema" />
        </service>

        <activity
            android:name=".AssistantActivity"
            android:label="AI Assistant"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.google.android.glass.category.DIRECTORY" />
            </intent-filter>
        </activity>

    </application>
</manifest>
