<?xml version="1.0" encoding="utf-8"?>
<!-- Dark chip behind the gallery's stationary title text. Same shape
     as the base-app cover-flow drawers. Mostly-opaque on purpose: a
     lighter translucent fill (#99 etc.) on KitKat-era hardware
     acceleration leaves edge ghosting as the chip re-centers on
     filename width changes. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E6000000" />
    <corners android:radius="8dp" />
</shape>
