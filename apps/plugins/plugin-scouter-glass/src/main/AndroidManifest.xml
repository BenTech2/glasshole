<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:allowBackup="true"
        android:label="Scouter"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <!-- Glass touchpad gesture support — required for the side-tap
             freeze-frame interaction on XE. -->
        <meta-data
            android:name="com.google.android.glass.TouchEnabledApplication"
            android:value="true" />

        <!-- Plugin SDK registration. The scouter doesn't talk to the
             phone yet (it's a pure on-glass gimmick), but registering
             as a plugin gets it into the app drawer / phone's plugin
             list and lets us add phone-side controls later. -->
        <service
            android:name=".ScouterPluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.glasshole.plugin.GLASS_PLUGIN" />
            </intent-filter>
            <meta-data android:name="com.glasshole.plugin.ID" android:value="scouter" />
            <meta-data android:name="com.glasshole.plugin.NAME" android:value="Scouter" />
            <meta-data android:name="com.glasshole.plugin.DESCRIPTION"
                android:value="Camera HUD with a circular reticle. Tap to lock on." />
        </service>

        <activity
            android:name=".ScouterActivity"
            android:label="Scouter"
            android:icon="@mipmap/ic_launcher"
            android:exported="true"
            android:screenOrientation="landscape"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.google.android.glass.category.DIRECTORY" />
            </intent-filter>
        </activity>
    </application>
</manifest>
