<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:label="GlassHole Notes"
        android:icon="@android:drawable/ic_menu_edit"
        android:theme="@style/Theme.GlassHoleGlass">

        <meta-data
            android:name="com.google.android.glass.TouchEnabledApplication"
            android:value="true" />

        <service
            android:name=".NotesGlassPluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.glasshole.plugin.GLASS_PLUGIN" />
            </intent-filter>
            <meta-data android:name="com.glasshole.plugin.ID" android:value="notes" />
        </service>

        <activity
            android:name=".NotesMenuActivity"
            android:label="GlassHole Notes"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.google.android.glass.category.DIRECTORY" />
            </intent-filter>
        </activity>

        <activity
            android:name=".DictateActivity"
            android:exported="false"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />

        <activity
            android:name=".NoteViewActivity"
            android:exported="false"
            android:theme="@style/Theme.GlassHoleGlass" />

        <activity
            android:name=".NoteListActivity"
            android:exported="false"
            android:theme="@style/Theme.GlassHoleGlass" />

    </application>
</manifest>
